# Goose:
GOOSE_DRIVER="postgres"
GOOSE_DBSTRING="postgres://<PostgreSQL username>:<PostgreSQL password>d@<PostgreSQL host>:<PostgreSQL port>/<Chirpy DB>"
GOOSE_MIGRATION_DIR="sql/schema"

# Chirpy:
DB_URL="${GOOSE_DBSTRING}?sslmode=disable"
#PLATFORM="dev" # Set this option to "dev" to enable develoepr mode. (boot.dev requirement)
#TOKEN_KEY=<Your Chirpy token key goes here, use this if you want access tokens to stay valid between server restarts or if you plan to run multiple server instances>
#POLKA_KEY="<Polka key>" # Issued in CH8, L4, only relevant if you're doing the tutorial